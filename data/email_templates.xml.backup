<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Quotation Email Template -->
    <record id="email_template_quotation" model="mail.template">

        <field name="name">Freight Quotation</field>
        <field name="model_id" ref="model_freight_quotation"/>
        <field name="subject">Freight Quotation ${object.name}</field>
        <field name="email_from">${(object.user_id.email_formatted or user.email_formatted) | safe}</field>
        <field name="email_to">${object.partner_id.email | safe}</field>
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
                <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 20px; text-align: center;">
                    <h2 style="margin: 0;">Freight Quotation</h2>
                </div>
                <div style="padding: 20px; background: #f9fafb;">
                    <p>Dear ${object.partner_id.name},</p>
                    <p>Thank you for your inquiry. Please find below our quotation for your freight requirements:</p>
                    
                    <div style="background: white; padding: 15px; border-radius: 8px; margin: 20px 0;">
                        <h3 style="color: #667eea; margin-top: 0;">Quotation Details</h3>
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="padding: 8px 0;"><strong>Quotation Number:</strong></td>
                                <td style="padding: 8px 0;">${object.name}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0;"><strong>Date:</strong></td>
                                <td style="padding: 8px 0;">${format_date(object.quotation_date)}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0;"><strong>Valid Until:</strong></td>
                                <td style="padding: 8px 0;">${format_date(object.validity_date)}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0;"><strong>Service Type:</strong></td>
                                <td style="padding: 8px 0;">${dict(object._fields['service_type'].selection).get(object.service_type)}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0;"><strong>Origin:</strong></td>
                                <td style="padding: 8px 0;">${object.origin_port_id.name}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0;"><strong>Destination:</strong></td>
                                <td style="padding: 8px 0;">${object.destination_port_id.name}</td>
                            </tr>
                            <tr style="border-top: 2px solid #667eea;">
                                <td style="padding: 12px 0;"><strong>Total Amount:</strong></td>
                                <td style="padding: 12px 0; font-size: 18px; color: #667eea;"><strong>${format_amount(object.total_amount, object.currency_id)}</strong></td>
                            </tr>
                        </table>
                    </div>
                    
                    <div style="text-align: center; margin: 30px 0;">
                        <a href="${object.get_portal_url()}" style="background: #667eea; color: white; padding: 12px 30px; text-decoration: none; border-radius: 5px; display: inline-block;">View Quotation</a>
                    </div>
                    
                    <p>If you have any questions, please don't hesitate to contact us.</p>
                    <p>Best regards,<br/>${object.user_id.name}</p>
                </div>
            </div>
        </field>
    </record>

    <!-- Quotation Confirmed Email Template -->
    <record id="email_template_quotation_confirmed" model="mail.template">
        <field name="name">Freight Quotation Confirmed</field>
        <field name="model_id" ref="model_freight_quotation"/>
        <field name="subject">Quotation ${object.name} Confirmed by Customer</field>
        <field name="email_from">${user.email_formatted | safe}</field>
        <field name="email_to">${object.user_id.email | safe}</field>
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif;">
                <p>Hello ${object.user_id.name},</p>
                <p>Good news! Customer <strong>${object.partner_id.name}</strong> has confirmed quotation <strong>${object.name}</strong>.</p>
                <p><strong>Total Amount:</strong> ${format_amount(object.total_amount, object.currency_id)}</p>
                <p>Please proceed with booking arrangements.</p>
                <p><a href="/web#id=${object.id}&amp;model=freight.quotation&amp;view_type=form">View Quotation</a></p>
            </div>
        </field>
    </record>

    <!-- Email Template: Quotation Accepted by Customer -->
    <record id="email_template_quotation_accepted" model="mail.template">
        <field name="name">Freight Quotation - Accepted by Customer</field>
        <field name="model_id" ref="model_freight_quotation"/>
        <field name="subject">✅ Quotation ${object.name} Accepted by Customer</field>
        <field name="email_from">${user.email_formatted | safe}</field>
        <field name="email_to">${object.user_id.email | safe}</field>
        <field name="body_html" type="html">
<![CDATA[
            <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
                <div style="background: #10B981; padding: 30px; text-align: center;">
                    <h1 style="color: #ffffff; margin: 0;">✅ Quotation Accepted!</h1>
                    <p style="color: #ffffff; margin: 10px 0 0 0;">${object.name}</p>
                </div>
                <div style="padding: 30px; background: #ffffff;">
                    <p style="font-size: 16px;">Great news! The customer has accepted the quotation.</p>
                    <div style="background: #f0fdf4; border-left: 4px solid #10B981; padding: 20px; margin: 20px 0;">
                        <h3 style="margin: 0 0 15px 0;">Customer Information</h3>
                        <p><strong>Customer:</strong> ${object.partner_id.name}</p>
                        <p><strong>Route:</strong> ${object.origin_port_id.code} → ${object.destination_port_id.code}</p>
                        <p><strong>Accepted On:</strong> ${format_datetime(object.customer_action_date)}</p>
                        <p><strong>Total Amount:</strong> ${format_amount(object.total_amount, object.currency_id)}</p>
                    </div>
                    <p><strong>Next Steps:</strong></p>
                    <ol>
                        <li>A draft booking has been automatically created</li>
                        <li>Review and complete the booking details</li>
                        <li>Coordinate with operations team</li>
                        <li>Send booking confirmation to customer</li>
                    </ol>
                    <div style="text-align: center; margin: 30px 0;">
                        <a href="/web#id=${object.id}&amp;model=freight.quotation&amp;view_type=form" 
                           style="display: inline-block; padding: 15px 40px; background: #10B981; color: #ffffff; text-decoration: none; border-radius: 8px;">
                            View Quotation
                        </a>
                    </div>
                </div>
            </div>
]]>
        </field>
    </record>
                        <h3 style="margin: 0 0 15px 0; color: #212121; font-size: 18px;">Customer Information</h3>
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="padding: 8px 0; color: #616161; font-size: 14px;">Customer:</td>
                                <td style="padding: 8px 0; color: #212121; font-weight: 600; text-align: right;">${object.partner_id.name}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0; color: #616161; font-size: 14px;">Route:</td>
                                <td style="padding: 8px 0; color: #212121; font-weight: 600; text-align: right;">${object.origin_port_id.code} → ${object.destination_port_id.code}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0; color: #616161; font-size: 14px;">Accepted On:</td>
                                <td style="padding: 8px 0; color: #212121; font-weight: 600; text-align: right;">${format_datetime(object.customer_action_date)}</td>
                            </tr>
                            <tr style="border-top: 2px solid #d1fae5;">
                                <td style="padding: 12px 0 0 0; color: #212121; font-size: 16px; font-weight: 700;">Total Amount:</td>
                                <td style="padding: 12px 0 0 0; color: #10B981; font-weight: 700; font-size: 20px; text-align: right;">${format_amount(object.total_amount, object.currency_id)}</td>
                            </tr>
                        </table>
                    </div>
                    <p style="font-size: 16px; color: #424242; line-height: 1.6; margin: 20px 0;">
                        <strong>Next Steps:</strong><br/>
                        1. A draft booking has been automatically created<br/>
                        2. Review and complete the booking details<br/>
                        3. Coordinate with operations team<br/>
                        4. Send booking confirmation to customer
                    </p>
                    <div style="text-align: center; margin: 30px 0;">
                        <a href="/web#id=${object.id}&amp;model=freight.quotation&amp;view_type=form" 
                           style="display: inline-block; padding: 15px 40px; background: #10B981; color: #ffffff; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 16px; text-transform: uppercase; letter-spacing: 0.5px;">
                            View Quotation
                        </a>
                    </div>
                </div>
                <div style="background: #f5f5f5; padding: 20px; text-align: center; border-top: 1px solid #e0e0e0;">
                    <p style="margin: 0; color: #757575; font-size: 12px;">
                        This is an automated notification from ${object.company_id.name}
                    </p>
                </div>
            </div>
        </field>
    </record>

    <!-- Email Template: Quotation Rejected by Customer -->
    <record id="email_template_quotation_rejected" model="mail.template">
        <field name="name">Freight Quotation - Rejected by Customer</field>
        <field name="model_id" ref="model_freight_quotation"/>
        <field name="subject">❌ Quotation ${object.name} Rejected by Customer</field>
        <field name="email_from">${user.email_formatted | safe}</field>
        <field name="email_to">${object.user_id.email | safe}</field>
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; background: #ffffff;">
                <div style="background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%); padding: 30px; text-align: center;">
                    <h1 style="color: #ffffff; margin: 0; font-size: 28px;">❌ Quotation Rejected</h1>
                    <p style="color: #ffffff; margin: 10px 0 0 0; opacity: 0.9;">${object.name}</p>
                </div>
                <div style="padding: 30px; background: #ffffff;">
                    <p style="font-size: 16px; color: #212121; margin-bottom: 20px;">
                        The customer has rejected the quotation.
                    </p>
                    <div style="background: #fef2f2; border-left: 4px solid #EF4444; padding: 20px; margin: 20px 0; border-radius: 8px;">
                        <h3 style="margin: 0 0 15px 0; color: #212121; font-size: 18px;">Rejection Details</h3>
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="padding: 8px 0; color: #616161; font-size: 14px;">Customer:</td>
                                <td style="padding: 8px 0; color: #212121; font-weight: 600; text-align: right;">${object.partner_id.name}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0; color: #616161; font-size: 14px;">Route:</td>
                                <td style="padding: 8px 0; color: #212121; font-weight: 600; text-align: right;">${object.origin_port_id.code} → ${object.destination_port_id.code}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0; color: #616161; font-size: 14px;">Rejected On:</td>
                                <td style="padding: 8px 0; color: #212121; font-weight: 600; text-align: right;">${format_datetime(object.customer_action_date)}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0; color: #616161; font-size: 14px;">Amount:</td>
                                <td style="padding: 8px 0; color: #212121; font-weight: 600; text-align: right;">${format_amount(object.total_amount, object.currency_id)}</td>
                            </tr>
                        </table>
                    </div>
                    % if object.rejection_reason:
                    <div style="background: #fff7ed; border: 2px solid #f59e0b; padding: 20px; margin: 20px 0; border-radius: 8px;">
                        <h4 style="margin: 0 0 10px 0; color: #212121; font-size: 16px;">
                            <span style="color: #f59e0b;">💬</span> Customer Feedback:
                        </h4>
                        <p style="margin: 0; color: #424242; font-size: 14px; line-height: 1.6; font-style: italic;">
                            "${object.rejection_reason}"
                        </p>
                    </div>
                    % endif
                    <p style="font-size: 16px; color: #424242; line-height: 1.6; margin: 20px 0;">
                        <strong>Recommended Actions:</strong><br/>
                        1. Review the rejection reason<br/>
                        2. Contact the customer to understand their concerns<br/>
                        3. Consider revising the quotation if appropriate<br/>
                        4. Update your pricing strategy if needed
                    </p>
                    <div style="text-align: center; margin: 30px 0;">
                        <a href="/web#id=${object.id}&amp;model=freight.quotation&amp;view_type=form" 
                           style="display: inline-block; padding: 15px 40px; background: #EF4444; color: #ffffff; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 16px; text-transform: uppercase; letter-spacing: 0.5px;">
                            View Quotation
                        </a>
                    </div>
                </div>
                <div style="background: #f5f5f5; padding: 20px; text-align: center; border-top: 1px solid #e0e0e0;">
                    <p style="margin: 0; color: #757575; font-size: 12px;">
                        This is an automated notification from ${object.company_id.name}
                    </p>
                </div>
            </div>
        </field>
    </record>

    <!-- Booking Confirmed Email Template -->
    <record id="email_template_booking_confirmed" model="mail.template">
        <field name="name">Freight Booking Confirmed</field>
        <field name="model_id" ref="model_freight_booking"/>
        <field name="subject">Booking Confirmation ${object.name}</field>
        <field name="email_from">${(object.user_id.email_formatted or user.email_formatted) | safe}</field>
        <field name="email_to">${object.partner_id.email | safe}</field>
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
                <div style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; padding: 20px; text-align: center;">
                    <h2 style="margin: 0;">Booking Confirmed</h2>
                </div>
                <div style="padding: 20px; background: #f9fafb;">
                    <p>Dear ${object.partner_id.name},</p>
                    <p>Your booking has been confirmed. Please find the details below:</p>
                    
                    <div style="background: white; padding: 15px; border-radius: 8px; margin: 20px 0;">
                        <h3 style="color: #10b981; margin-top: 0;">Booking Details</h3>
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="padding: 8px 0;"><strong>Booking Number:</strong></td>
                                <td style="padding: 8px 0;">${object.name}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0;"><strong>Booking Date:</strong></td>
                                <td style="padding: 8px 0;">${format_date(object.booking_date)}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0;"><strong>Service Type:</strong></td>
                                <td style="padding: 8px 0;">${dict(object._fields['service_type'].selection).get(object.service_type)}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0;"><strong>Carrier:</strong></td>
                                <td style="padding: 8px 0;">${object.carrier_id.name}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0;"><strong>Vessel/Flight:</strong></td>
                                <td style="padding: 8px 0;">${object.vessel_name or 'TBA'}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0;"><strong>Voyage/Flight Number:</strong></td>
                                <td style="padding: 8px 0;">${object.voyage_number or 'TBA'}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0;"><strong>ETD:</strong></td>
                                <td style="padding: 8px 0;">${format_datetime(object.etd, tz=object.user_id.tz)}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0;"><strong>ETA:</strong></td>
                                <td style="padding: 8px 0;">${format_datetime(object.eta, tz=object.user_id.tz)}</td>
                            </tr>
                        </table>
                    </div>
                    
                    <div style="text-align: center; margin: 30px 0;">
                        <a href="${object.get_portal_url()}" style="background: #10b981; color: white; padding: 12px 30px; text-decoration: none; border-radius: 5px; display: inline-block;">View Booking</a>
                    </div>
                    
                    <p>We will keep you updated on the shipment progress.</p>
                    <p>Best regards,<br/>${object.user_id.name}</p>
                </div>
            </div>
        </field>
    </record>

    <!-- Shipment Status Update Email Template -->
    <record id="email_template_shipment_status_update" model="mail.template">
        <field name="name">Shipment Status Update</field>
        <field name="model_id" ref="model_freight_shipment"/>
        <field name="subject">Shipment ${object.name} Status Update</field>
        <field name="email_from">${user.email_formatted | safe}</field>
        <field name="email_to">${object.partner_id.email | safe}</field>
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
                <div style="background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); color: white; padding: 20px; text-align: center;">
                    <h2 style="margin: 0;">Shipment Status Update</h2>
                </div>
                <div style="padding: 20px; background: #f9fafb;">
                    <p>Dear ${object.partner_id.name},</p>
                    <p>Your shipment status has been updated:</p>
                    
                    <div style="background: white; padding: 15px; border-radius: 8px; margin: 20px 0;">
                        <h3 style="color: #3b82f6; margin-top: 0;">Shipment Information</h3>
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="padding: 8px 0;"><strong>Shipment Number:</strong></td>
                                <td style="padding: 8px 0;">${object.name}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0;"><strong>Current Status:</strong></td>
                                <td style="padding: 8px 0;">
                                    <span style="background: #3b82f6; color: white; padding: 4px 12px; border-radius: 12px; font-size: 12px;">
                                        ${dict(object._fields['state'].selection).get(object.state)}
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0;"><strong>Origin:</strong></td>
                                <td style="padding: 8px 0;">${object.origin_location_id.name if object.origin_location_id else 'N/A'}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0;"><strong>Destination:</strong></td>
                                <td style="padding: 8px 0;">${object.destination_location_id.name if object.destination_location_id else 'N/A'}</td>
                            </tr>
                        </table>
                    </div>
                    
                    <div style="text-align: center; margin: 30px 0;">
                        <a href="${object.get_portal_url()}" style="background: #3b82f6; color: white; padding: 12px 30px; text-decoration: none; border-radius: 5px; display: inline-block;">Track Shipment</a>
                    </div>
                    
                    <p>Thank you for choosing our services.</p>
                </div>
            </div>
        </field>
    </record>

    <!-- Shipment Delivered Email Template -->
    <record id="email_template_shipment_delivered" model="mail.template">
        <field name="name">Shipment Delivered</field>
        <field name="model_id" ref="model_freight_shipment"/>
        <field name="subject">Shipment ${object.name} Delivered</field>
        <field name="email_from">${user.email_formatted | safe}</field>
        <field name="email_to">${object.partner_id.email | safe}</field>
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
                <div style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; padding: 20px; text-align: center;">
                    <h2 style="margin: 0;">✓ Shipment Delivered</h2>
                </div>
                <div style="padding: 20px; background: #f9fafb;">
                    <p>Dear ${object.partner_id.name},</p>
                    <p>Great news! Your shipment has been successfully delivered.</p>
                    
                    <div style="background: white; padding: 15px; border-radius: 8px; margin: 20px 0;">
                        <h3 style="color: #10b981; margin-top: 0;">Delivery Details</h3>
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="padding: 8px 0;"><strong>Shipment Number:</strong></td>
                                <td style="padding: 8px 0;">${object.name}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0;"><strong>Delivery Date:</strong></td>
                                <td style="padding: 8px 0;">${format_date(object.delivery_date) if object.delivery_date else 'Today'}</td>
                            </tr>
                            <tr>
                                <td style="padding: 8px 0;"><strong>Destination:</strong></td>
                                <td style="padding: 8px 0;">${object.destination_location_id.name if object.destination_location_id else 'N/A'}</td>
                            </tr>
                        </table>
                    </div>
                    
                    <div style="text-align: center; margin: 30px 0;">
                        <a href="${object.get_portal_url()}" style="background: #10b981; color: white; padding: 12px 30px; text-decoration: none; border-radius: 5px; display: inline-block;">View Shipment Details</a>
                    </div>
                    
                    <p>Thank you for your business. We look forward to serving you again.</p>
                    <p>Best regards,<br/>Your Freight Team</p>
                </div>
            </div>
        </field>
    </record>

</odoo>
