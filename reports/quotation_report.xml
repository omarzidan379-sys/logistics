<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Quotation Report Template -->
    <template id="report_quotation_document">
        <t t-call="web.external_layout">
            <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)"/>
            <div class="page">
                <div class="oe_structure"/>
                
                <h2 class="mt16">
                    <span>Freight Quotation</span>
                    <span t-field="doc.name"/>
                </h2>

                <div class="row mt32 mb32">
                    <div class="col-6">
                        <strong>Customer:</strong><br/>
                        <div t-field="doc.partner_id" 
                             t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True}'/>
                    </div>
                    <div class="col-6">
                        <strong>Quotation Date:</strong> <span t-field="doc.quotation_date"/><br/>
                        <strong>Valid Until:</strong> <span t-field="doc.validity_date"/><br/>
                        <strong>Salesperson:</strong> <span t-field="doc.user_id"/><br/>
                    </div>
                </div>

                <div class="row mt32 mb32">
                    <div class="col-12">
                        <h4>Shipment Details</h4>
                        <table class="table table-sm">
                            <tr>
                                <td><strong>Service Type:</strong></td>
                                <td><span t-field="doc.service_type"/></td>
                                <td><strong>Direction:</strong></td>
                                <td><span t-field="doc.shipment_direction"/></td>
                            </tr>
                            <tr>
                                <td><strong>Origin:</strong></td>
                                <td><span t-field="doc.origin_port_id"/></td>
                                <td><strong>Destination:</strong></td>
                                <td><span t-field="doc.destination_port_id"/></td>
                            </tr>
                            <tr t-if="doc.container_type">
                                <td><strong>Container Type:</strong></td>
                                <td><span t-field="doc.container_type"/></td>
                                <td><strong>Quantity:</strong></td>
                                <td><span t-field="doc.container_qty"/></td>
                            </tr>
                            <tr>
                                <td><strong>Cargo Description:</strong></td>
                                <td colspan="3"><span t-field="doc.cargo_description"/></td>
                            </tr>
                        </table>
                    </div>
                </div>

                <h4>Pricing Details</h4>
                <table class="table table-sm o_main_table">
                    <thead>
                        <tr>
                            <th>Description</th>
                            <th class="text-right">Quantity</th>
                            <th class="text-right">Unit Price</th>
                            <th class="text-right">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="doc.line_ids" t-as="line">
                            <td><span t-field="line.description"/></td>
                            <td class="text-right">
                                <span t-field="line.quantity"/>
                            </td>
                            <td class="text-right">
                                <span t-field="line.unit_price" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                            </td>
                            <td class="text-right">
                                <span t-field="line.subtotal" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <div class="clearfix">
                    <div class="row">
                        <div class="col-6"/>
                        <div class="col-6">
                            <table class="table table-sm">
                                <tr>
                                    <td><strong>Subtotal:</strong></td>
                                    <td class="text-right">
                                        <span t-field="doc.subtotal_amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>Tax:</strong></td>
                                    <td class="text-right">
                                        <span t-field="doc.tax_amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                                <tr class="border-black">
                                    <td><strong>Total:</strong></td>
                                    <td class="text-right">
                                        <span t-field="doc.total_amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="row mt32" t-if="doc.notes">
                    <div class="col-12">
                        <h4>Terms and Conditions</h4>
                        <p t-field="doc.notes"/>
                    </div>
                </div>

                <div class="oe_structure"/>
            </div>
        </t>
    </template>

    <!-- Quotation Report Action -->
    <record id="action_report_freight_quotation" model="ir.actions.report">
        <field name="name">Freight Quotation</field>
        <field name="model">freight.quotation</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">freight_management.report_quotation_document</field>
        <field name="report_file">freight_management.report_quotation_document</field>
        <field name="binding_model_id" ref="model_freight_quotation"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
