<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Quotation Dashboard Template -->
    <t t-name="freight_management.QuotationDashboard">
        <div class="o_freight_quotation_dashboard">
            <div class="container-fluid">
                <div class="row mb-4">
                    <div class="col-12">
                        <h2 class="mb-4">
                            <i class="fa fa-file-text-o me-2"/>Quotation Dashboard
                        </h2>
                    </div>
                </div>
                
                <t t-if="state.loading">
                    <div class="text-center py-5">
                        <i class="fa fa-spinner fa-spin fa-3x text-primary"/>
                        <p class="mt-3">Loading dashboard data...</p>
                    </div>
                </t>
                
                <t t-else="">
                    <div class="row g-4">
                        <!-- Draft Quotations -->
                        <div class="col-md-3">
                            <div class="card border-secondary shadow-sm h-100 cursor-pointer" t-on-click="() => this.openQuotations('draft')">
                                <div class="card-body text-center">
                                    <i class="fa fa-file-o fa-3x text-secondary mb-3"/>
                                    <h3 class="mb-2" t-esc="state.quotations.draft"/>
                                    <p class="text-muted mb-0">Draft Quotations</p>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Sent Quotations -->
                        <div class="col-md-3">
                            <div class="card border-info shadow-sm h-100 cursor-pointer" t-on-click="() => this.openQuotations('sent')">
                                <div class="card-body text-center">
                                    <i class="fa fa-paper-plane fa-3x text-info mb-3"/>
                                    <h3 class="mb-2" t-esc="state.quotations.sent"/>
                                    <p class="text-muted mb-0">Sent Quotations</p>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Approved Quotations -->
                        <div class="col-md-3">
                            <div class="card border-success shadow-sm h-100 cursor-pointer" t-on-click="() => this.openQuotations('approved')">
                                <div class="card-body text-center">
                                    <i class="fa fa-check-circle fa-3x text-success mb-3"/>
                                    <h3 class="mb-2" t-esc="state.quotations.approved"/>
                                    <p class="text-muted mb-0">Approved Quotations</p>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Total Amount -->
                        <div class="col-md-3">
                            <div class="card border-primary shadow-sm h-100">
                                <div class="card-body text-center">
                                    <i class="fa fa-usd fa-3x text-primary mb-3"/>
                                    <h3 class="mb-2" t-esc="state.quotations.total_amount"/>
                                    <p class="text-muted mb-0">Total Value</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </div>
        </div>
    </t>

    <!-- Shipment Tracking Template -->
    <t t-name="freight_management.ShipmentTracking">
        <div class="o_freight_shipment_tracking">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fa fa-map-marker me-2"/>Shipment Tracking
                    </h5>
                </div>
                <div class="card-body">
                    <!-- Progress Bar -->
                    <div class="mb-4">
                        <div class="progress" style="height: 30px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" 
                                 role="progressbar" 
                                 t-att-style="'width: ' + state.progress + '%'"
                                 t-esc="state.progress + '%'"/>
                        </div>
                    </div>
                    
                    <!-- Milestones Timeline -->
                    <div class="timeline">
                        <t t-foreach="state.milestones" t-as="milestone" t-key="milestone.id">
                            <div class="timeline-item" t-att-class="milestone.completed ? 'completed' : ''">
                                <div class="timeline-marker">
                                    <i class="fa" t-att-class="getStateIcon(milestone.state)"/>
                                </div>
                                <div class="timeline-content">
                                    <h6 t-esc="milestone.name"/>
                                    <p class="text-muted mb-0" t-esc="milestone.date"/>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </div>
    </t>

    <!-- Rate Calculator Template -->
    <t t-name="freight_management.RateCalculator">
        <div class="o_freight_rate_calculator">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-lg-8 mx-auto">
                        <div class="card shadow">
                            <div class="card-header bg-primary text-white">
                                <h4 class="mb-0">
                                    <i class="fa fa-calculator me-2"/>Freight Rate Calculator
                                </h4>
                            </div>
                            <div class="card-body">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Origin Port</label>
                                        <select class="form-select" t-model="state.origin">
                                            <option value="">Select Origin...</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Destination Port</label>
                                        <select class="form-select" t-model="state.destination">
                                            <option value="">Select Destination...</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Service Type</label>
                                        <select class="form-select" t-model="state.serviceType">
                                            <option value="fcl">FCL</option>
                                            <option value="lcl">LCL</option>
                                            <option value="air">Air</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Container Type</label>
                                        <select class="form-select" t-model="state.containerType">
                                            <option value="20gp">20' GP</option>
                                            <option value="40gp">40' GP</option>
                                            <option value="40hc">40' HC</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Weight (KG)</label>
                                        <input type="number" class="form-control" t-model="state.weight"/>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Volume (CBM)</label>
                                        <input type="number" class="form-control" t-model="state.volume"/>
                                    </div>
                                </div>
                                
                                <div class="mt-4 text-center">
                                    <button class="btn btn-primary btn-lg me-2" 
                                            t-on-click="calculateRate"
                                            t-att-disabled="state.calculating">
                                        <i class="fa fa-calculator me-2"/>
                                        <t t-if="state.calculating">Calculating...</t>
                                        <t t-else="">Calculate Rate</t>
                                    </button>
                                    <button class="btn btn-secondary btn-lg" 
                                            t-on-click="clearCalculation">
                                        <i class="fa fa-refresh me-2"/>Clear
                                    </button>
                                </div>
                                
                                <!-- Result Display -->
                                <t t-if="state.result">
                                    <div class="alert alert-success mt-4">
                                        <h5>Calculated Rate</h5>
                                        <p class="mb-0">
                                            <strong>Total: </strong>
                                            <span t-esc="state.result.total_amount"/>
                                        </p>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>

    <!-- Container Tracker Template -->
    <t t-name="freight_management.ContainerTracker">
        <div class="o_freight_container_tracker">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="fa fa-cube me-2"/>Container Tracking
                    </h5>
                </div>
                <div class="card-body">
                    <t t-if="state.loading">
                        <div class="text-center py-3">
                            <i class="fa fa-spinner fa-spin fa-2x"/>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Container #</th>
                                        <th>Type</th>
                                        <th>Status</th>
                                        <th>Weight</th>
                                        <th>Demurrage</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.containers" t-as="container" t-key="container.id">
                                        <tr t-on-click="() => this.selectContainer(container.id)" 
                                            class="cursor-pointer">
                                            <td t-esc="container.name"/>
                                            <td t-esc="container.container_type"/>
                                            <td>
                                                <span t-att-class="getStateBadge(container.state)" 
                                                      t-esc="container.state"/>
                                            </td>
                                            <td t-esc="container.vgm_weight"/>
                                            <td>
                                                <span t-if="container.demurrage_days > 0" 
                                                      class="text-danger">
                                                    <t t-esc="container.demurrage_days"/> days
                                                </span>
                                                <span t-else="" class="text-success">-</span>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </t>
                </div>
            </div>
        </div>
    </t>

    <!-- Booking Wizard Template -->
    <t t-name="freight_management.BookingWizard">
        <div class="o_freight_booking_wizard">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-lg-10 mx-auto">
                        <div class="card shadow-lg">
                            <div class="card-header bg-primary text-white">
                                <h4 class="mb-0">
                                    <i class="fa fa-ship me-2"/>Create Booking
                                </h4>
                            </div>
                            <div class="card-body">
                                <!-- Step Indicator -->
                                <div class="wizard-steps mb-4">
                                    <div class="d-flex justify-content-between">
                                        <div class="step" t-att-class="getStepClass(1)">
                                            <div class="step-number">1</div>
                                            <div class="step-label">Quotation</div>
                                        </div>
                                        <div class="step" t-att-class="getStepClass(2)">
                                            <div class="step-number">2</div>
                                            <div class="step-label">Carrier Details</div>
                                        </div>
                                        <div class="step" t-att-class="getStepClass(3)">
                                            <div class="step-number">3</div>
                                            <div class="step-label">Confirmation</div>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Step Content -->
                                <div class="wizard-content">
                                    <!-- Step 1: Quotation Selection -->
                                    <t t-if="state.step === 1">
                                        <h5 class="mb-3">Select Quotation</h5>
                                        <div class="mb-3">
                                            <label class="form-label">Quotation</label>
                                            <select class="form-select" t-model="state.quotationId">
                                                <option value="">Select a quotation...</option>
                                            </select>
                                        </div>
                                    </t>
                                    
                                    <!-- Step 2: Carrier Details -->
                                    <t t-if="state.step === 2">
                                        <h5 class="mb-3">Carrier &amp; Vessel Details</h5>
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label">Carrier</label>
                                                <select class="form-select" t-model="state.carrierId">
                                                    <option value="">Select carrier...</option>
                                                </select>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Vessel Name</label>
                                                <input type="text" class="form-control" t-model="state.vesselName"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Voyage Number</label>
                                                <input type="text" class="form-control" t-model="state.voyageNumber"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Booking Reference</label>
                                                <input type="text" class="form-control" t-model="state.bookingReference"/>
                                            </div>
                                        </div>
                                    </t>
                                    
                                    <!-- Step 3: Confirmation -->
                                    <t t-if="state.step === 3">
                                        <h5 class="mb-3">Confirm Booking Details</h5>
                                        <div class="alert alert-info">
                                            <p>Please review the booking details before confirming.</p>
                                        </div>
                                    </t>
                                </div>
                                
                                <!-- Navigation Buttons -->
                                <div class="d-flex justify-content-between mt-4">
                                    <button class="btn btn-secondary" 
                                            t-on-click="prevStep"
                                            t-att-disabled="state.step === 1">
                                        <i class="fa fa-arrow-left me-2"/>Previous
                                    </button>
                                    
                                    <t t-if="state.step &lt; 3">
                                        <button class="btn btn-primary" t-on-click="nextStep">
                                            Next<i class="fa fa-arrow-right ms-2"/>
                                        </button>
                                    </t>
                                    <t t-else="">
                                        <button class="btn btn-success" 
                                                t-on-click="createBooking"
                                                t-att-disabled="state.processing">
                                            <i class="fa fa-check me-2"/>
                                            <t t-if="state.processing">Creating...</t>
                                            <t t-else="">Create Booking</t>
                                        </button>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>

    <!-- Map Widget Template -->
    <t t-name="freight_management.MapWidget">
        <div class="o_freight_map_widget">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="fa fa-map me-2"/>Route Map
                    </h5>
                </div>
                <div class="card-body p-0">
                    <t t-if="state.loading">
                        <div class="text-center py-5">
                            <i class="fa fa-spinner fa-spin fa-2x text-primary"/>
                            <p class="mt-3">Loading map...</p>
                        </div>
                    </t>
                    <t t-else="">
                        <div t-ref="map" class="freight-map-container"/>
                    </t>
                </div>
            </div>
        </div>
    </t>

</templates>