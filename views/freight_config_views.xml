<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Freight Configuration Settings -->
    <record id="view_freight_config_settings" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.freight</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Freight" name="freight_management">
                    <block title="Default Settings">
                        <setting>
                            <label for="freight_free_time_days"/>
                            <div class="text-muted">
                                Default free time for containers in days
                            </div>
                            <field name="freight_free_time_days"/>
                        </setting>
                        <setting>
                            <label for="freight_demurrage_rate"/>
                            <div class="text-muted">
                                Default demurrage rate per day
                            </div>
                            <field name="freight_demurrage_rate"/>
                        </setting>
                        <setting>
                            <label for="freight_detention_rate"/>
                            <div class="text-muted">
                                Default detention rate per day
                            </div>
                            <field name="freight_detention_rate"/>
                        </setting>
                    </block>
                    
                    <block title="EDI Integration">
                        <setting>
                            <field name="edi_enabled"/>
                            <label for="edi_enabled"/>
                            <div class="text-muted">
                                Enable EDI integration with carriers and customs
                            </div>
                        </setting>
                        <setting invisible="not edi_enabled">
                            <label for="edi_endpoint"/>
                            <field name="edi_endpoint"/>
                            <label for="edi_username"/>
                            <field name="edi_username"/>
                            <label for="edi_password"/>
                            <field name="edi_password" password="True"/>
                        </setting>
                    </block>
                    
                    <block title="API Configuration">
                        <setting>
                            <label for="api_rate_limit"/>
                            <div class="text-muted">
                                Maximum API requests per minute
                            </div>
                            <field name="api_rate_limit"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
    
    <!-- Settings Action -->
    <record id="action_freight_config" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'freight_management'}</field>
    </record>
</odoo>
