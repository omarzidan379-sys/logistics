<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Freight Location Form View -->
    <record id="view_freight_location_form" model="ir.ui.view">
        <field name="name">freight.location.form</field>
        <field name="model">freight.location</field>
        <field name="arch" type="xml">
            <form string="Freight Location">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Location Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="location_type"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="country_id"/>
                            <field name="state_id"/>
                            <field name="city"/>
                        </group>
                    </group>
                    <group string="Address">
                        <field name="address" nolabel="1"/>
                    </group>
                    <group string="GPS Coordinates">
                        <group>
                            <field name="latitude"/>
                        </group>
                        <group>
                            <field name="longitude"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <!-- Freight Location Tree View -->
    <record id="view_freight_location_tree" model="ir.ui.view">
        <field name="name">freight.location.tree</field>
        <field name="model">freight.location</field>
        <field name="arch" type="xml">
            <tree string="Freight Locations">
                <field name="code"/>
                <field name="name"/>
                <field name="location_type"/>
                <field name="city"/>
                <field name="country_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>
    
    <!-- Freight Location Search View -->
    <record id="view_freight_location_search" model="ir.ui.view">
        <field name="name">freight.location.search</field>
        <field name="model">freight.location</field>
        <field name="arch" type="xml">
            <search string="Search Locations">
                <field name="name"/>
                <field name="code"/>
                <field name="city"/>
                <field name="country_id"/>
                <filter name="ports" string="Ports" domain="[('location_type', '=', 'port')]"/>
                <filter name="airports" string="Airports" domain="[('location_type', '=', 'airport')]"/>
                <filter name="warehouses" string="Warehouses" domain="[('location_type', '=', 'warehouse')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_type" string="Type" context="{'group_by': 'location_type'}"/>
                    <filter name="group_by_country" string="Country" context="{'group_by': 'country_id'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Freight Location Action -->
    <record id="action_freight_location" model="ir.actions.act_window">
        <field name="name">Locations</field>
        <field name="res_model">freight.location</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first freight location
            </p>
            <p>
                Define ports, airports, warehouses and other locations used in freight operations.
            </p>
        </field>
    </record>
</odoo>
