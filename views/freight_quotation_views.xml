<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Freight Quotation Form View -->
    <record id="view_freight_quotation_form" model="ir.ui.view">
        <field name="name">freight.quotation.form</field>
        <field name="model">freight.quotation</field>
        <field name="arch" type="xml">
            <form string="Freight Quotation" class="o_freight_quotation_form">
                <header>
                    <button name="action_send" string="Send to Customer" type="object" 
                            class="oe_highlight" invisible="state != 'draft'" icon="fa-paper-plane"/>
                    <button name="action_approve" string="Approve" type="object" 
                            class="oe_highlight" invisible="state != 'sent'" icon="fa-check-circle"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state not in ['draft', 'sent']" icon="fa-times-circle"/>
                    <button name="action_set_to_draft" string="Set to Draft" type="object" invisible="state != 'cancelled'" icon="fa-undo"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,sent,approved"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_bookings" type="object" class="oe_stat_button" icon="fa-ship">
                            <field name="booking_count" widget="statinfo" string="Bookings"/>
                        </button>
                        <button name="action_view_shipments" type="object" class="oe_stat_button" icon="fa-truck">
                            <field name="shipment_count" widget="statinfo" string="Shipments"/>
                        </button>
                    </div>
                    
                    <widget name="web_ribbon" title="Approved" bg_color="text-bg-success" invisible="state != 'approved'"/>
                    <widget name="web_ribbon" title="Cancelled" bg_color="text-bg-danger" invisible="state != 'cancelled'"/>
                    <widget name="web_ribbon" title="Expired" bg_color="text-bg-warning" invisible="state != 'expired'"/>
                    
                    <div class="oe_title">
                        <h1 class="d-flex align-items-center">
                            <i class="fa fa-file-text-o me-2 text-primary"/>
                            <field name="name" readonly="1" class="text-break"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="Customer Information" class="border-start border-primary border-3 ps-3">
                            <field name="partner_id" options="{'no_create': True}" widget="res_partner_many2one"/>
                            <field name="contact_id" options="{'no_create': True}"/>
                            <field name="user_id" widget="many2one_avatar_user"/>
                        </group>
                        <group string="Quotation Details" class="border-start border-info border-3 ps-3">
                            <field name="quotation_date" widget="date"/>
                            <field name="validity_date" widget="date"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Route &amp; Cargo" name="route_cargo">
                            <group>
                                <group string="🚢 Service Details" class="bg-light p-3 rounded">
                                    <field name="service_type" widget="radio" options="{'horizontal': true}"/>
                                    <field name="shipment_direction" widget="radio" options="{'horizontal': true}"/>
                                    <field name="incoterm_id"/>
                                </group>
                            </group>
                            
                            <group>
                                <group string="📍 Origin" class="border-start border-success border-3 ps-3">
                                    <field name="origin_port_id" options="{'no_create': True}"/>
                                    <field name="origin_address" placeholder="Pickup address..."/>
                                </group>
                                <group string="📍 Destination" class="border-start border-danger border-3 ps-3">
                                    <field name="destination_port_id" options="{'no_create': True}"/>
                                    <field name="destination_address" placeholder="Delivery address..."/>
                                </group>
                            </group>
                            
                            <group string="📦 Cargo Information" class="bg-light p-3 rounded mt-3">
                                <group>
                                    <field name="cargo_description" placeholder="Describe the cargo..."/>
                                    <field name="commodity_id"/>
                                    <field name="container_type" invisible="service_type not in ['fcl']"/>
                                    <field name="container_qty" invisible="service_type not in ['fcl']"/>
                                </group>
                                <group>
                                    <label for="total_weight" string="Weight"/>
                                    <div class="o_row">
                                        <field name="total_weight" class="oe_inline"/>
                                        <span class="oe_inline">KG</span>
                                    </div>
                                    <label for="total_volume" string="Volume"/>
                                    <div class="o_row">
                                        <field name="total_volume" class="oe_inline"/>
                                        <span class="oe_inline">CBM</span>
                                    </div>
                                    <label for="chargeable_weight" string="Chargeable Weight"/>
                                    <div class="o_row">
                                        <field name="chargeable_weight" class="oe_inline"/>
                                        <span class="oe_inline">KG</span>
                                    </div>
                                    <field name="total_packages"/>
                                </group>
                            </group>
                            
                            <group string="⚠️ Special Requirements" class="mt-3">
                                <group>
                                    <field name="is_dangerous_goods" widget="boolean_toggle"/>
                                    <field name="is_temperature_controlled" widget="boolean_toggle"/>
                                </group>
                                <group>
                                    <field name="special_instructions" placeholder="Any special handling instructions..."/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="💰 Pricing" name="pricing">
                            <field name="line_ids">
                                <tree editable="bottom" decoration-info="charge_type_id" decoration-muted="quantity == 0">
                                    <field name="sequence" widget="handle"/>
                                    <field name="charge_type_id" options="{'no_create': True}"/>
                                    <field name="description" optional="show"/>
                                    <field name="quantity"/>
                                    <field name="unit_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="cost_price" widget="monetary" options="{'currency_field': 'currency_id'}" groups="freight_management.group_freight_manager"/>
                                    <field name="tax_ids" widget="many2many_tags" optional="hide"/>
                                    <field name="subtotal" widget="monetary" options="{'currency_field': 'currency_id'}" sum="Subtotal"/>
                                    <field name="tax_amount" widget="monetary" options="{'currency_field': 'currency_id'}" optional="hide"/>
                                    <field name="total" widget="monetary" options="{'currency_field': 'currency_id'}" sum="Total"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </tree>
                            </field>
                            
                            <group class="oe_subtotal_footer oe_right mt-3">
                                <div class="row">
                                    <div class="col-6"/>
                                    <div class="col-6">
                                        <table class="table table-sm o_total_table">
                                            <tr>
                                                <td class="text-end"><strong>Subtotal:</strong></td>
                                                <td class="text-end">
                                                    <field name="subtotal_amount" widget="monetary" options="{'currency_field': 'currency_id'}" nolabel="1"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="text-end"><strong>Tax:</strong></td>
                                                <td class="text-end">
                                                    <field name="tax_amount" widget="monetary" options="{'currency_field': 'currency_id'}" nolabel="1"/>
                                                </td>
                                            </tr>
                                            <tr class="border-top border-dark">
                                                <td class="text-end"><strong>Total:</strong></td>
                                                <td class="text-end">
                                                    <field name="total_amount" nolabel="1" class="oe_subtotal_footer_separator" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                                </td>
                                            </tr>
                                            <tr groups="freight_management.group_freight_manager" class="border-top">
                                                <td class="text-end text-muted">Cost:</td>
                                                <td class="text-end text-muted">
                                                    <field name="total_cost" widget="monetary" options="{'currency_field': 'currency_id'}" nolabel="1"/>
                                                </td>
                                            </tr>
                                            <tr groups="freight_management.group_freight_manager">
                                                <td class="text-end text-success"><strong>Profit:</strong></td>
                                                <td class="text-end text-success">
                                                    <field name="profit_amount" widget="monetary" options="{'currency_field': 'currency_id'}" nolabel="1"/>
                                                </td>
                                            </tr>
                                            <tr groups="freight_management.group_freight_manager">
                                                <td class="text-end text-success">Margin:</td>
                                                <td class="text-end text-success">
                                                    <field name="profit_margin" nolabel="1"/> %
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </group>
                        </page>
                        
                        <page string="📄 Terms &amp; Conditions" name="terms">
                            <field name="notes" placeholder="Enter terms and conditions, payment terms, delivery terms, etc..." options="{'resizable': true}"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Freight Quotation Tree View -->
    <record id="view_freight_quotation_tree" model="ir.ui.view">
        <field name="name">freight.quotation.tree</field>
        <field name="model">freight.quotation</field>
        <field name="arch" type="xml">
            <tree string="Freight Quotations" 
                  decoration-info="state=='draft'" 
                  decoration-success="state=='approved'" 
                  decoration-muted="state=='cancelled'"
                  decoration-warning="state=='sent'"
                  sample="1">
                <field name="name" decoration-bf="1"/>
                <field name="quotation_date" optional="show"/>
                <field name="partner_id" widget="many2one_avatar"/>
                <field name="origin_port_id" optional="show"/>
                <field name="destination_port_id" optional="show"/>
                <field name="service_type" optional="show" widget="badge"/>
                <field name="total_amount" widget="monetary" sum="Total" decoration-bf="1"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="validity_date" optional="show"/>
                <field name="user_id" widget="many2one_avatar_user" optional="show"/>
                <field name="state" widget="badge" 
                       decoration-info="state=='draft'" 
                       decoration-success="state=='approved'" 
                       decoration-warning="state=='sent'"
                       decoration-danger="state=='cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- Freight Quotation Kanban View -->
    <record id="view_freight_quotation_kanban" model="ir.ui.view">
        <field name="name">freight.quotation.kanban</field>
        <field name="model">freight.quotation</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="total_amount"/>
                <field name="currency_id"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong><br/>
                                    <span class="o_kanban_record_subtitle"><field name="partner_id"/></span>
                                </div>
                                <span class="float-end badge badge-pill">
                                    <field name="total_amount" widget="monetary"/>
                                </span>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="quotation_date"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Freight Quotation Search View -->
    <record id="view_freight_quotation_search" model="ir.ui.view">
        <field name="name">freight.quotation.search</field>
        <field name="model">freight.quotation</field>
        <field name="arch" type="xml">
            <search string="Search Quotations">
                <field name="name" string="Quotation Number"/>
                <field name="partner_id"/>
                <field name="origin_port_id"/>
                <field name="destination_port_id"/>
                <field name="user_id"/>
                <filter string="My Quotations" name="my_quotations" domain="[('user_id', '=', uid)]"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Sent" name="sent" domain="[('state', '=', 'sent')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Expired" name="expired" domain="[('validity_date', '&lt;', context_today().strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter string="Quotation Date" name="quotation_date" date="quotation_date"/>
                <group expand="0" string="Group By">
                    <filter string="Customer" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Salesperson" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Service Type" name="group_service" context="{'group_by': 'service_type'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Quotation Date" name="group_date" context="{'group_by': 'quotation_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Freight Quotation Action -->
    <record id="action_freight_quotation" model="ir.actions.act_window">
        <field name="name">Quotations</field>
        <field name="res_model">freight.quotation</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="context">{'search_default_my_quotations': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first freight quotation
            </p>
            <p>
                Create quotations for your customers with detailed pricing breakdown.
            </p>
        </field>
    </record>
</odoo>
