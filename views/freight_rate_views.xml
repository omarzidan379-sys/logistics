<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Freight Rate Form View -->
    <record id="view_freight_rate_form" model="ir.ui.view">
        <field name="name">freight.rate.form</field>
        <field name="model">freight.rate</field>
        <field name="arch" type="xml">
            <form string="Freight Rate">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="carrier_id"/>
                            <field name="service_type"/>
                            <field name="container_type" invisible="service_type not in ['fcl']" required="service_type == 'fcl'"/>
                        </group>
                        <group>
                            <field name="rate_type"/>
                            <field name="rate_amount" widget="monetary"/>
                            <field name="currency_id"/>
                            <field name="transit_time_days"/>
                        </group>
                    </group>
                    <group>
                        <group string="Route">
                            <field name="origin_port_id"/>
                            <field name="destination_port_id"/>
                        </group>
                        <group string="Validity">
                            <field name="valid_from"/>
                            <field name="valid_to"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Additional notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Freight Rate Tree View -->
    <record id="view_freight_rate_tree" model="ir.ui.view">
        <field name="name">freight.rate.tree</field>
        <field name="model">freight.rate</field>
        <field name="arch" type="xml">
            <tree string="Freight Rates">
                <field name="name"/>
                <field name="origin_port_id"/>
                <field name="destination_port_id"/>
                <field name="carrier_id"/>
                <field name="service_type"/>
                <field name="container_type"/>
                <field name="rate_amount" widget="monetary"/>
                <field name="currency_id" invisible="1"/>
                <field name="rate_type"/>
                <field name="valid_from"/>
                <field name="valid_to"/>
                <field name="active" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Freight Rate Search View -->
    <record id="view_freight_rate_search" model="ir.ui.view">
        <field name="name">freight.rate.search</field>
        <field name="model">freight.rate</field>
        <field name="arch" type="xml">
            <search string="Search Rates">
                <field name="name"/>
                <field name="origin_port_id"/>
                <field name="destination_port_id"/>
                <field name="carrier_id"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="FCL" name="fcl" domain="[('service_type', '=', 'fcl')]"/>
                <filter string="LCL" name="lcl" domain="[('service_type', '=', 'lcl')]"/>
                <filter string="Air" name="air" domain="[('service_type', '=', 'air')]"/>
                <group expand="0" string="Group By">
                    <filter string="Carrier" name="group_carrier" context="{'group_by': 'carrier_id'}"/>
                    <filter string="Service Type" name="group_service" context="{'group_by': 'service_type'}"/>
                    <filter string="Rate Type" name="group_rate_type" context="{'group_by': 'rate_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Freight Rate Action -->
    <record id="action_freight_rate" model="ir.actions.act_window">
        <field name="name">Freight Rates</field>
        <field name="res_model">freight.rate</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first freight rate
            </p>
        </field>
    </record>
</odoo>
