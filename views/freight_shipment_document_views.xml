<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Freight Shipment Document Form View -->
    <record id="view_freight_shipment_document_form" model="ir.ui.view">
        <field name="name">freight.shipment.document.form</field>
        <field name="model">freight.shipment.document</field>
        <field name="arch" type="xml">
            <form string="Shipment Document">
                <sheet>
                    <group>
                        <group>
                            <field name="shipment_id"/>
                            <field name="name"/>
                            <field name="document_type"/>
                        </group>
                        <group>
                            <field name="upload_date"/>
                            <field name="uploaded_by"/>
                        </group>
                    </group>
                    <group>
                        <field name="document_file" filename="file_name"/>
                        <field name="file_name" invisible="1"/>
                    </group>
                    <group>
                        <field name="notes" placeholder="Notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Freight Shipment Document Tree View -->
    <record id="view_freight_shipment_document_tree" model="ir.ui.view">
        <field name="name">freight.shipment.document.tree</field>
        <field name="model">freight.shipment.document</field>
        <field name="arch" type="xml">
            <tree string="Documents">
                <field name="name"/>
                <field name="document_type"/>
                <field name="shipment_id"/>
                <field name="upload_date"/>
                <field name="uploaded_by"/>
            </tree>
        </field>
    </record>

    <!-- Freight Shipment Document Action -->
    <record id="action_freight_shipment_document" model="ir.actions.act_window">
        <field name="name">Shipment Documents</field>
        <field name="res_model">freight.shipment.document</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
