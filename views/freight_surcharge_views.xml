<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Freight Surcharge Form View -->
    <record id="view_freight_surcharge_form" model="ir.ui.view">
        <field name="name">freight.surcharge.form</field>
        <field name="model">freight.surcharge</field>
        <field name="arch" type="xml">
            <form string="Freight Surcharge">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="surcharge_type"/>
                            <field name="carrier_id"/>
                            <field name="service_type"/>
                        </group>
                        <group>
                            <field name="calculation_method"/>
                            <field name="amount" invisible="calculation_method != 'fixed'" required="calculation_method == 'fixed'" widget="monetary"/>
                            <field name="percentage" invisible="calculation_method != 'percentage'" required="calculation_method == 'percentage'"/>
                            <field name="currency_id" invisible="calculation_method != 'fixed'"/>
                        </group>
                    </group>
                    <group>
                        <group string="Validity Period">
                            <field name="valid_from"/>
                            <field name="valid_to"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Additional notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Freight Surcharge Tree View -->
    <record id="view_freight_surcharge_tree" model="ir.ui.view">
        <field name="name">freight.surcharge.tree</field>
        <field name="model">freight.surcharge</field>
        <field name="arch" type="xml">
            <tree string="Freight Surcharges">
                <field name="name"/>
                <field name="surcharge_type"/>
                <field name="carrier_id"/>
                <field name="calculation_method"/>
                <field name="amount" widget="monetary"/>
                <field name="percentage"/>
                <field name="currency_id" invisible="1"/>
                <field name="valid_from"/>
                <field name="valid_to"/>
                <field name="active" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Freight Surcharge Action -->
    <record id="action_freight_surcharge" model="ir.actions.act_window">
        <field name="name">Surcharges</field>
        <field name="res_model">freight.surcharge</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first surcharge
            </p>
        </field>
    </record>
</odoo>
